# Environment Variables
# Copy this file to .env and fill in the values before running the project.
# Never commit .env to version control.

# ── Snowflake ──────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_username_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_DATABASE=your_database_here
SNOWFLAKE_SCHEMA=your_schema_here
SNOWFLAKE_WAREHOUSE=your_warehouse_here
SNOWFLAKE_ROLE=your_role_here

# ── IBM DB2 ────────────────────────────────────────────────────────────────────
DB2_HOST=your_db2_host_here
DB2_PORT=50000
DB2_DATABASE=your_database_here
DB2_USER=your_username_here
DB2_PASSWORD=your_password_here
