{
  "name": "Snowflake & DB2 Dev Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql",
        "koszti.snowflake-driver-for-sqltools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    },
    "jetbrains": {
      "plugins": [
        "com.intellij.database",
        "ru.adelf.idea.dotenv"
      ],
      "settings": {
        "python.interpreter.path": "/opt/venv/bin/python"
      }
    }
  },
  "containerEnv": {
    "IBM_DB_HOME": "/opt/ibm/clidriver",
    "LD_LIBRARY_PATH": "/opt/ibm/clidriver/lib"
  },
  "postCreateCommand": "uv sync --frozen --all-extras && [ -f .env ] || cp .env.example .env",
  "remoteUser": "root"
}
